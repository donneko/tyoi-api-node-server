{
  "name": "tyoi-api-server",
  "version": "0.4.5",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx ./src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck",
    "build": "tsc && rm -rf dist/public && cp -R src/public dist/public",
    "start": "node ./dist/main.js"
  },
  "type": "module",
  "author": "",
  "license": "MIT",
  "description": "Small local API and static file server framework built with Express and TypeScript.",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-slow-down": "^3.1.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "minimist": "^1.2.8",
    "morgan": "^1.10.1",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
