{
  "name": "tyoi",
  "version": "0.0.1",
  "scripts": {
    "tyoi dev": "tsx ./src/main.ts dev",
    "tyoi": "tsx ./src/main.ts",
    "test": "tsc --noEmit",
    "compile": "tsc && rm -rf dist/templates && cp -R src/templates dist/templates",
    "build":"npm run test && npm run compile && npm pack --dry-run",
    "prepack": "npm run compile",
    "prepublishOnly": "npm run test && npm run compile",
    "start": "node ./dist/main.js"
  },
  "bin": {
    "tyoi": "./dist/main.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "public"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donneko/tyoi-api-node-server"
  },
  "keywords": [
    "server",
    "api",
    "express",
    "typescript",
    "nodejs",
    "static-server"
  ],
  "type": "module",
  "main":"./dist/index.js",
  "exports":{
    ".":"./dist/index.js"
  },
  "author": "丼猫",
  "license": "MIT",
  "description": "Small local API and static file server framework built with Express and TypeScript.",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-slow-down": "^3.1.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "minimist": "^1.2.8",
    "morgan": "^1.10.1",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/minimist": "^1.2.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
