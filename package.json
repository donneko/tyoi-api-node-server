{
  "name": "@donneko/tyoi-server",
  "version": "0.0.7",
  "scripts": {
    "test": "npm run test:use && npm run test:vitest",
    "test:vitest": "npx vitest run",
    "test:type": "npx tsc --noEmit",
    "test:templates": "npx tsc -p tsconfig.templates.json && npx tsc --ignoreConfig --noEmit --allowJs --checkJs templates/project/static-ts/public/main/assets/app.js && node --check templates/project/static-ts/public/main/assets/app.js && node --check templates/project/realtime-ts/public/main/assets/app.js",
    "test:use--init": "npm pack && tsx ./scripts/initPlayground.ts",
    "test:use": "npm run test:use--init && tsx ./scripts/testPlayground.ts",
    "test:ci": "npm run test:type && npm run test:templates && npm run check:format:check && npm run test:vitest",
    "test:nonTTY": "npm run test </dev/null",
    "check:format:write": "npx prettier . --write",
    "check:format:check": "npx prettier . --check",
    "check:lint": "npx eslint .",
    "check:lint:fix": "npx eslint . --fix",
    "docs": "npm run docs:typedoc:build && npm run docs:vitepress:build",
    "docs:dev": "npx vitepress dev docs",
    "docs:typedoc:build": "npx typedoc",
    "docs:vitepress:build": "npx vitepress build docs",
    "docs:preview": "npx vitepress preview docs",
    "dev": "npx tsx ./src/main.ts",
    "start": "node ./dist/main.js",
    "compile": "rm -rf dist && tsc",
    "build": "npm run test:type && npm run compile",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.14"
  },
  "bin": {
    "tyoi": "dist/main.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs/*.md",
    "docs/src",
    "examples/features",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "public",
    "templates",
    "tyoi.config.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donneko/tyoi-server.git"
  },
  "keywords": [
    "server",
    "api",
    "express",
    "typescript",
    "static-server"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "author": "丼猫",
  "license": "MIT",
  "description": "Small local API and static file server framework built with Express and TypeScript.",
  "dependencies": {
    "@donneko/tyoi-cli": "^0.0.2",
    "@donneko/tyoi-logger": "^0.1.0",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "minimist": "^1.2.8",
    "morgan": "^1.10.1",
    "open": "^11.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/minimist": "^1.2.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.7.0",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  }
}
