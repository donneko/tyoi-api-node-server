{
  "name": "@donneko/tyoi-server",
  "version": "0.0.6",
  "scripts": {
    "test": "npm run use-test && npm run vi-test",
    "vi-test": "npx vitest run",
    "ts-test": "tsc --noEmit",
    "pg-init": "npm pack && tsx ./scripts/initPlayground.ts",
    "use-test": "npm run pg-init && tsx ./scripts/testPlayground.ts",
    "start": "node ./dist/main.js",
    "compile": "rm -rf dist && tsc",
    "build": "npm run ts-test && npm run compile",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "check:format--write": "prettier . --write",
    "check:format--check": "prettier . --check"
  },
  "engines": {
    "node": ">=20.14"
  },
  "bin": {
    "tyoi": "dist/main.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "doc",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "public",
    "templates",
    "tyoi.config.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donneko/tyoi-api-node-server.git"
  },
  "keywords": [
    "server",
    "api",
    "express",
    "typescript",
    "static-server"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "author": "丼猫",
  "license": "MIT",
  "description": "Small local API and static file server framework built with Express and TypeScript.",
  "dependencies": {
    "@donneko/tyoi-cli": "^0.0.1",
    "@donneko/tyoi-logger": "^0.0.1",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "minimist": "^1.2.8",
    "morgan": "^1.10.1",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.7.0",
    "@types/qrcode-terminal": "^0.12.2",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  }
}
