{
  "name": "@donneko/tyoi-server",
  "version": "0.0.4",
  "scripts": {
    "dev": "tsx ./src/main.ts dev",
    "dev-test": "tsx ./test/server.ts",
    "test": "tsc --noEmit",
    "compile": "rm -rf dist && tsc && cp -R src/templates dist/templates",
    "build": "npm run test && npm run compile",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "start": "node ./dist/main.js",
    "d-play": "tsx ./scripts/initPlayground.ts"
  },
  "engines": {
    "node": ">=20.14"
  },
  "bin": {
    "tyoi": "./dist/main.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "doc",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "public"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donneko/tyoi-api-node-server.git"
  },
  "keywords": [
    "server",
    "api",
    "express",
    "typescript",
    "static-server"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "author": "丼猫",
  "license": "MIT",
  "description": "Small local API and static file server framework built with Express and TypeScript.",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "minimist": "^1.2.8",
    "morgan": "^1.10.1",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.7.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
